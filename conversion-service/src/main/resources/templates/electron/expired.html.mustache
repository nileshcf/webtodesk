<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{appTitle}} — Trial Expired</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #0a0a0f;
      color: #f5f5f7;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }

    /* Background gradient mesh */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background:
        radial-gradient(ellipse 60% 40% at 50% 0%, rgba(234, 88, 12, 0.08), transparent),
        radial-gradient(ellipse 40% 50% at 80% 70%, rgba(99, 102, 241, 0.05), transparent),
        radial-gradient(ellipse 50% 40% at 20% 80%, rgba(168, 85, 247, 0.04), transparent);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 420px;
      padding: 0 24px;
    }

    .lock-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 28px;
      border-radius: 20px;
      background: rgba(234, 88, 12, 0.1);
      border: 1px solid rgba(234, 88, 12, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      animation: float 3s ease-in-out infinite;
    }

    h1 {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #fff, rgba(255,255,255,0.65));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .message {
      font-size: 15px;
      color: rgba(255, 255, 255, 0.4);
      line-height: 1.7;
      margin-bottom: 32px;
    }

    .app-name {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 8px;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.3);
      margin-bottom: 28px;
      font-weight: 500;
    }

    .upgrade-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 36px;
      border-radius: 12px;
      border: none;
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      cursor: pointer;
      background: linear-gradient(135deg, #ea580c, #f97316);
      box-shadow: 0 4px 24px rgba(234, 88, 12, 0.3);
      transition: all 0.3s ease;
      text-decoration: none;
      letter-spacing: 0.1px;
    }
    .upgrade-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(234, 88, 12, 0.45);
    }
    .upgrade-btn:active {
      transform: translateY(0);
    }

    .footer {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 11px;
      color: rgba(255, 255, 255, 0.15);
      z-index: 1;
    }
    .footer a {
      color: rgba(255, 255, 255, 0.25);
      text-decoration: none;
    }
    .footer a:hover {
      color: rgba(255, 255, 255, 0.4);
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="lock-icon">🔒</div>  
    <div class="app-name">{{appTitle}}</div>
    <h1>Trial Expired</h1>
    <p class="message">{{lockMessage}}</p>
    <a class="upgrade-btn" id="upgrade-link" href="#">
      Upgrade Now →
    </a>
  </div>
  <div class="footer">
    Built with <a href="https://webtodesk.com" target="_blank">WebToDesk</a>
  </div>
  <script>
    // Open upgrade URL via Electron IPC (if available) or fallback to shell.openExternal
    document.getElementById('upgrade-link').addEventListener('click', function(e) {
      e.preventDefault();
      var upgradeUrl = '{{upgradeUrl}}';
      try {
        var { ipcRenderer } = require('electron');
        ipcRenderer.send('open-external', upgradeUrl);
      } catch (_) {
        window.open(upgradeUrl, '_blank');
      }
    });
  </script>
</body>
</html>
