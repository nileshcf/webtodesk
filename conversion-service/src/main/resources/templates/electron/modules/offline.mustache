// Module: offline — Tier: TRIAL
// Injects a drop-down notification island when network fails.
// Non-blocking: does NOT replace the page. Dismisses automatically on reconnect.

function setup(mainWindow, config) {
  if (!config.modules?.includes('offline')) return;

  var NETWORK_ERRORS = new Set([-2, -21, -100, -102, -105, -106, -109, -112, -118, -130, -137, -138]);

  mainWindow.webContents.on('did-fail-load', function(event, errorCode, errorDescription) {
    if (!NETWORK_ERRORS.has(errorCode)) return;
    var msg = errorCode === -2 ? "You're offline" : (errorDescription || 'Connection lost');
    mainWindow.webContents.send('wtd-offline', { message: msg });
  });

  mainWindow.webContents.on('did-finish-load', function() {
    mainWindow.webContents.send('wtd-online');
  });
}

function preloadSetup(contextBridge, ipcRenderer, config) {
  if (!config.modules?.includes('offline')) return;

  function showIsland(message) {
    var el = document.getElementById('wtd-offline-island');
    if (el) {
      var msgEl = document.getElementById('wtd-offline-msg');
      if (msgEl) msgEl.textContent = message;
      return;
    }

    var island = document.createElement('div');
    island.id = 'wtd-offline-island';
    island.style.cssText =
      'position:fixed;top:16px;left:50%;transform:translateX(-50%) translateY(-140%);' +
      'z-index:2147483646;' +
      'background:rgba(12,12,18,0.94);' +
      'border:1px solid rgba(239,68,68,0.28);' +
      'border-radius:40px;' +
      'padding:9px 16px 9px 14px;' +
      'display:flex;align-items:center;gap:9px;' +
      'backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);' +
      'box-shadow:0 8px 32px rgba(0,0,0,0.45),0 0 0 1px rgba(255,255,255,0.04);' +
      'transition:transform 0.38s cubic-bezier(0.34,1.56,0.64,1);' +
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;' +
      'pointer-events:all;user-select:none;';

    island.innerHTML =
      '<div style="width:8px;height:8px;border-radius:50%;background:#ef4444;flex-shrink:0;' +
        'box-shadow:0 0 0 3px rgba(239,68,68,0.18);animation:wtdOfPulse 1.6s ease-in-out infinite;"></div>' +
      '<span id="wtd-offline-msg" style="font-size:13px;font-weight:500;' +
        'color:rgba(255,255,255,0.85);white-space:nowrap;letter-spacing:-0.1px;">' + message + '</span>' +
      '<button id="wtd-offline-retry" style="' +
        'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);' +
        'color:rgba(255,255,255,0.55);border-radius:20px;padding:3px 11px;' +
        'font-size:11px;font-weight:600;cursor:pointer;margin-left:2px;' +
        'font-family:inherit;transition:background 0.15s,color 0.15s;">Retry</button>' +
      '<style>@keyframes wtdOfPulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.85);}}</style>';

    document.documentElement.appendChild(island);

    var retryBtn = island.querySelector('#wtd-offline-retry');
    retryBtn.addEventListener('click', function() { window.location.reload(); });
    retryBtn.addEventListener('mouseenter', function() {
      this.style.background = 'rgba(255,255,255,0.14)';
      this.style.color = 'rgba(255,255,255,0.9)';
    });
    retryBtn.addEventListener('mouseleave', function() {
      this.style.background = 'rgba(255,255,255,0.08)';
      this.style.color = 'rgba(255,255,255,0.55)';
    });

    requestAnimationFrame(function() {
      island.style.transform = 'translateX(-50%) translateY(0)';
    });
  }

  function hideIsland() {
    var el = document.getElementById('wtd-offline-island');
    if (!el) return;
    el.style.transform = 'translateX(-50%) translateY(-140%)';
    setTimeout(function() { if (el.parentNode) el.parentNode.removeChild(el); }, 380);
  }

  ipcRenderer.on('wtd-offline', function(_, data) { showIsland(data.message || "You're offline"); });
  ipcRenderer.on('wtd-online',  function()        { hideIsland(); });

  window.addEventListener('offline', function() { showIsland("You're offline"); });
  window.addEventListener('online',  function() { hideIsland(); });
}

function teardown() {}

module.exports = { setup, preloadSetup, teardown };
