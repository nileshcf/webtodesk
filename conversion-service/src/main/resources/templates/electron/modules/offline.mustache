// Module: offline — Tier: FREE
// Shows a friendly error page when the network connection is lost.
function setup(mainWindow, config) {
  if (!config.modules?.includes('offline')) return;

  mainWindow.webContents.on('did-fail-load', (event, errorCode, errorDescription, validatedURL) => {
    // Error codes for network-related failures
    if (errorCode === -2 || errorCode === -105 || errorCode === -106 || errorCode === -21) {
      mainWindow.webContents.loadURL('data:text/html;charset=utf-8,' + encodeURIComponent(`
        <!DOCTYPE html>
        <html lang="en">
        <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>No Connection</title>
          <style>
            * { box-sizing: border-box; margin: 0; padding: 0; }
            body {
              display: flex; align-items: center; justify-content: center;
              height: 100vh; background: #0f0f13;
              font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
              color: #fff;
            }
            .container { text-align: center; padding: 40px; max-width: 420px; }
            .icon { font-size: 72px; margin-bottom: 24px; display: block; }
            h1 { font-size: 26px; font-weight: 700; margin-bottom: 10px; color: #fff; }
            p { color: rgba(255,255,255,0.45); font-size: 15px; line-height: 1.6; margin-bottom: 28px; }
            button {
              background: #4f46e5; color: white; border: none;
              padding: 13px 32px; border-radius: 10px;
              font-size: 15px; font-weight: 600; cursor: pointer;
              transition: background 0.2s;
            }
            button:hover { background: #4338ca; }
          </style>
        </head>
        <body>
          <div class="container">
            <span class="icon">📡</span>
            <h1>No Internet Connection</h1>
            <p>Check your network connection and try again. The page will reload automatically when connectivity is restored.</p>
            <button onclick="window.location.reload()">Try Again</button>
          </div>
          <script>
            window.addEventListener('online', () => window.location.reload());
          </script>
        </body>
        </html>
      `));
    }
  });
}

function preloadSetup() {}

function teardown() {}

module.exports = { setup, preloadSetup, teardown };
