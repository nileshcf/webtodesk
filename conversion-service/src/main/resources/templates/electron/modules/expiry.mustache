// Module: expiry — Tier: TRIAL (auto-injected by platform into every non-dev build)
// Baked-in 30-day TTL from build date. Not user-configurable.
// Locks the app on startup (main process) and during a session (renderer).

var LOCK_ID        = '__wtd-expiry-lock';
var CHECK_INTERVAL = 60000; // re-check every 60 s

// ── Main process: loads expired.html and blocks navigation when expired ───────
function setup(mainWindow, config) {
  if (!config.modules?.includes('expiry')) return;

  var exp        = config.expiry || {};
  var expiresAt  = exp.expiresAt || null;
  if (!expiresAt) return;

  var expiryTime = new Date(expiresAt).getTime();
  if (isNaN(expiryTime)) return;

  var path        = require('path');
  var expiredPage = path.join(__dirname, '..', 'expired.html');

  function isExpired() { return Date.now() >= expiryTime; }

  function loadLockPage() {
    try {
      var cur = mainWindow.webContents.getURL();
      if (cur && cur.includes('expired.html')) return;
      mainWindow.loadFile(expiredPage);
    } catch (_) {}
  }

  // Block any navigation once locked
  function preventNavigation(event) { event.preventDefault(); }

  function lockMain() {
    loadLockPage();
    mainWindow.webContents.on('will-navigate', preventNavigation);
    mainWindow.webContents.on('will-redirect', preventNavigation);
  }

  // Check after each page load so SPA navigations don't bypass the lock
  mainWindow.webContents.on('did-finish-load', function() {
    var cur = mainWindow.webContents.getURL();
    if (cur && cur.includes('expired.html')) return;
    if (isExpired()) lockMain();
  });

  // Schedule a precision lock exactly when the TTL fires (max safe setTimeout: ~24.8 days)
  var msLeft = expiryTime - Date.now();
  if (msLeft > 0 && msLeft < 2147483647) {
    setTimeout(function() { if (isExpired()) lockMain(); }, msLeft + 500);
  } else if (msLeft <= 0) {
    // Already expired before the main window fully loaded — lock on first paint
    mainWindow.webContents.once('did-finish-load', function() { lockMain(); });
  }
}

function preloadSetup(contextBridge, ipcRenderer, config) {
  if (!config.modules || config.modules.indexOf('expiry') === -1) return;

  var exp         = config.expiry || {};
  var expiresAt   = exp.expiresAt   || null;
  var lockMessage = exp.lockMessage || 'Your trial has expired. Please upgrade to continue.';
  var upgradeUrl  = exp.upgradeUrl  || 'https://webtodesk.com/pricing';

  if (!expiresAt) return;

  var expiryTime = new Date(expiresAt).getTime();
  if (isNaN(expiryTime)) return;

  function isExpired() {
    return Date.now() >= expiryTime;
  }

  function showLockScreen() {
    if (document.getElementById(LOCK_ID)) return;

    // ── Outer overlay ─────────────────────────────────────────────────────
    var overlay = document.createElement('div');
    overlay.id  = LOCK_ID;
    overlay.style.cssText = [
      'position:fixed',
      'top:0', 'left:0',
      'width:100%', 'height:100%',
      'background:#0f0f11',
      'color:#f5f5f7',
      'z-index:2147483647',
      'display:flex',
      'flex-direction:column',
      'align-items:center',
      'justify-content:center',
      'font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif',
      'pointer-events:all',
      '-webkit-app-region:no-drag'
    ].join(';');

    // ── Lock icon ─────────────────────────────────────────────────────────
    var icon = document.createElement('div');
    icon.style.cssText = 'font-size:52px;margin-bottom:20px;line-height:1;';
    icon.textContent   = '\uD83D\uDD12';  // 🔒

    // ── Heading ───────────────────────────────────────────────────────────
    var heading = document.createElement('h2');
    heading.style.cssText = [
      'margin:0 0 12px',
      'font-size:22px',
      'font-weight:600',
      'letter-spacing:-0.3px'
    ].join(';');
    heading.textContent = 'Trial Expired';

    // ── Message ───────────────────────────────────────────────────────────
    var msg = document.createElement('p');
    msg.style.cssText = [
      'margin:0 0 30px',
      'font-size:15px',
      'color:#a0a0b0',
      'max-width:360px',
      'text-align:center',
      'line-height:1.6'
    ].join(';');
    msg.textContent = lockMessage;

    // ── Upgrade button ────────────────────────────────────────────────────
    var btn = document.createElement('button');
    btn.style.cssText = [
      'background:#ea580c',
      'color:#fff',
      'border:none',
      'padding:11px 32px',
      'border-radius:8px',
      'font-size:15px',
      'font-weight:600',
      'cursor:pointer',
      'letter-spacing:0.1px',
      'transition:opacity 0.15s'
    ].join(';');
    btn.textContent   = 'Upgrade Now \u2192';  // → arrow
    btn.onmouseover   = function() { btn.style.opacity = '0.85'; };
    btn.onmouseout    = function() { btn.style.opacity = '1'; };
    btn.onclick       = function() {
      try { ipcRenderer.send('open-external', upgradeUrl); } catch (_) {}
    };

    overlay.appendChild(icon);
    overlay.appendChild(heading);
    overlay.appendChild(msg);
    overlay.appendChild(btn);

    var root = document.body || document.documentElement;
    if (root) {
      root.appendChild(overlay);
      // Prevent scroll / pointer interaction on the underlying page
      if (document.body) {
        document.body.style.overflow = 'hidden';
        document.body.style.pointerEvents = 'none';
      }
    }
  }

  function checkAndLock() {
    if (isExpired()) showLockScreen();
  }

  // ── Initial check ─────────────────────────────────────────────────────────
  if (document.body) {
    checkAndLock();
  } else {
    window.addEventListener('DOMContentLoaded', checkAndLock);
  }

  // ── Periodic check (catches expiry during a long session) ─────────────────
  setInterval(checkAndLock, CHECK_INTERVAL);
}

function teardown() {
  try {
    var el = document.getElementById(LOCK_ID);
    if (el) el.remove();
  } catch (_) {}
}

module.exports = { setup, preloadSetup, teardown };
