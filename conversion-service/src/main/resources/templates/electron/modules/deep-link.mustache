// Module: deep-link — Tier: PRO
// Registers a custom URL protocol so the app can be opened via myapp://... links.
const { app } = require('electron');

// Must run before app.whenReady() — called at require() time from the top of main.js
const _deepLinkLockAcquired = app.requestSingleInstanceLock();
if (!_deepLinkLockAcquired) {
  app.quit();
}

function setup(mainWindow, config) {
  if (!config.modules?.includes('deep-link')) return;
  if (!_deepLinkLockAcquired) return;

  const { ipcMain } = require('electron');
  const protocol = config.projectName?.toLowerCase().replace(/[^a-z0-9]/g, '') || 'webtodesk';

  if (process.defaultApp) {
    if (process.argv.length >= 2) {
      app.setAsDefaultProtocolClient(protocol, process.execPath, [process.argv[1]]);
    }
  } else {
    app.setAsDefaultProtocolClient(protocol);
  }

  app.on('open-url', (event, url) => {
    event.preventDefault();
    if (mainWindow) {
      mainWindow.webContents.send('deep-link-url', url);
    }
  });

  // Windows: handle second-instance deep links
  app.on('second-instance', (event, commandLine) => {
    if (mainWindow) {
      if (mainWindow.isMinimized()) mainWindow.restore();
      mainWindow.focus();
      const deepLinkUrl = commandLine.find(arg => arg.startsWith(protocol + '://'));
      if (deepLinkUrl) {
        mainWindow.webContents.send('deep-link-url', deepLinkUrl);
      }
    }
  });
}

function teardown() {}

module.exports = { setup, teardown };
