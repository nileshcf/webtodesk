// Set platform attribute before first paint so CSS selectors work immediately
if (document.body) {
  document.body.dataset.platform = process.platform;
} else {
  document.addEventListener('DOMContentLoaded', function() {
    if (document.body) document.body.dataset.platform = process.platform;
  });
}
